# ============================================================
#  IBM Watsonx.ai — Nutrition Agent Environment Configuration
# ============================================================

# IBM Cloud API Key (required) — get from https://cloud.ibm.com/iam/apikeys
IBM_API_KEY=your_ibm_cloud_api_key_here

# IBM Watsonx.ai Project ID (required) — get from your Watsonx.ai project settings
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# IBM Watsonx.ai API URL (default: Dallas region)
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Flask secret key (change this to a strong random string in production)
FLASK_SECRET_KEY=nutrition-agent-secret-key-change-me

# Flask environment
FLASK_ENV=development
FLASK_DEBUG=True

# Application port
PORT=5000
